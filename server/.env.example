NODE_ENV=development

# ClickHouse configuration
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# PostgreSQL configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
BETTER_AUTH_SECRET=your-secret-key-here

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AppSumo (optional - cloud only)
APPSUMO_CLIENT_ID=
APPSUMO_CLIENT_SECRET=

# R2 Storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Provider-neutral visitor identity (server-only, disabled without DB policy approval)
IDENTITY_KEY_ENCRYPTION_SECRET=
IDENTITY_BLOCKED_DOMAINS=
IDENTITY_CONNECTOR_URL=
IDENTITY_PILOT_MONTHLY_BUDGET_CENTS=75000
CUSTOMERS_AI_API_KEY=
CUSTOMERS_AI_RESOLVE_URL=
CUSTOMERS_AI_HEALTH_URL=
CUSTOMERS_AI_DELETE_URL=
