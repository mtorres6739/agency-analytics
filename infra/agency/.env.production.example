DOMAIN_NAME=analytics.example.com
LEGACY_DOMAIN_NAME=analytics-old.example.com
BASE_URL=https://analytics.example.com
GHCR_OWNER=your-github-organization
IMAGE_TAG=full-40-character-commit-sha
APP_NAME="Bold Analytics"
ENFORCE_AGENCY_TWO_FACTOR=true
TRACKING_INSTALLER_ENABLED=false
TRACKING_AUTO_DEPLOY_ENABLED=false
TRACKING_ANALYTICS_ORIGIN=https://analytics.example.com
TRACKING_PATH_PREFIX=/__bold-analytics
TRACKING_WORKER_PREFIX=bold-analytics-tracker

# Server-only provider credentials. Use least-privilege, expiring tokens.
CLOUDFLARE_API_TOKEN=
CF_ACCOUNT_ID=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
GITHUB_TOKEN=
# 32+ random characters used only to encrypt per-site identity secrets in Postgres.
IDENTITY_KEY_ENCRYPTION_SECRET=generate-at-least-32-random-bytes
IDENTITY_BLOCKED_DOMAINS=theaccidentdoctor.com,neuron-connect.com,arizonatattooremoval.com,r2law.co,cummingspest.com
# Provider identity remains disabled until its connection record is approved.
# URLs come from the signed sandbox documentation; do not guess vendor endpoints.
IDENTITY_CONNECTOR_URL=
IDENTITY_PILOT_MONTHLY_BUDGET_CENTS=75000
CUSTOMERS_AI_API_KEY=
CUSTOMERS_AI_RESOLVE_URL=
CUSTOMERS_AI_HEALTH_URL=
CUSTOMERS_AI_DELETE_URL=
CUSTOMERS_AI_WEBHOOK_SECRET=
CUSTOMERS_AI_COST_MICROS=
RB2B_API_KEY=
RB2B_RESOLVE_URL=
RB2B_HEALTH_URL=
RB2B_DELETE_URL=
RB2B_WEBHOOK_SECRET=
RB2B_COST_MICROS=
PDL_API_KEY=
PDL_ENRICH_URL=
PDL_COST_MICROS=
# JSON map keyed by numeric site id. Keep only in the root-readable production env.
GHL_SITE_CREDENTIALS_JSON={}

BETTER_AUTH_SECRET=generate-at-least-32-random-bytes
DISABLE_SIGNUP=true
DISABLE_TELEMETRY=true
DEPLOYMENT=agency
LITE_DASHBOARD=false
CLUSTER_WORKERS=4

CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=generate-a-unique-password
POSTGRES_DB=analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=generate-a-unique-password
REDIS_PASSWORD=generate-a-unique-password

MAPBOX_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
EMAIL_FROM="Analytics <analytics@example.com>"

S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
REPORTS_BUCKET=agency-analytics-reports
REPORTS_PREFIX=agency-analytics/reports
AGENCY_BACKUP_PATH=/srv/agency-backups

BACKUP_S3_URI=s3://agency-analytics-backups/production
BACKUP_AGE_RECIPIENT=age1replace-with-public-recipient
